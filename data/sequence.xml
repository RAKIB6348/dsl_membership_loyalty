<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_membership_code" model="ir.sequence">
        <field name="name">Membership Unique Code</field>
        <field name="code">dsl_membership_loyalty.membership_code_sequence</field>
        <field name="prefix">MEM-</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_agent_code" model="ir.sequence">
        <field name="name">Agent Unique Code</field>
        <field name="code">dsl_membership_loyalty.agent_code_sequence</field>
        <field name="prefix">AGT-</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>