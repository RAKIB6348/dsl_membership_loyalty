<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_membership_agent_card" model="ir.actions.report">
        <field name="name">Membership / Agent Card</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dsl_membership_loyalty.report_membership_agent_card_template</field>
        <field name="report_file">dsl_membership_loyalty.report_membership_agent_card_template</field>
        <field name="print_report_name">'%s Card' % (object.name)</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_membership_agent_card_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="partner">

                <div class="page" style="font-family: Arial, sans-serif; padding: 18px;">

                    <div style="
                        width: 390px;
                        margin: 0 auto;
                        border-radius: 22px;
                        overflow: hidden;
                        background: #ffffff;
                        border: 1px solid #edf0f5;
                        box-shadow: 0 12px 35px rgba(15, 23, 42, 0.14);
                    ">

                        <!-- Header -->
                        <div style="
                            background-color: #875A7B;
                            color: #ffffff;
                            padding: 30px 24px 26px;
                            text-align: center;
                        ">

                            <t t-if="partner.image_1920">
                                <img t-att-src="'data:image/png;base64,%s' % partner.image_1920.decode('utf-8')"
                                     style="
                                        width: 90px;
                                        height: 90px;
                                        border-radius: 50%;
                                        object-fit: cover;
                                        border: 4px solid #ffffff;
                                     "/>
                            </t>

                            <t t-else="">
                                <div style="
                                    width: 90px;
                                    height: 90px;
                                    border-radius: 50%;
                                    margin: 0 auto;
                                    border: 4px solid #ffffff;
                                    background-color: #9b6b90;
                                    color: #ffffff;
                                    font-size: 40px;
                                    font-weight: bold;
                                    line-height: 90px;
                                    text-align: center;
                                ">
                                    <span t-esc="(partner.name or 'U')[:1]"/>
                                </div>
                            </t>

                            <h2 style="margin: 16px 0 6px; font-size: 24px; color: #ffffff;">
                                <t t-if="partner.is_agent">Agent Card</t>
                                <t t-elif="partner.is_membership">Membership Card</t>
                                <t t-else="">Contact Card</t>
                            </h2>

                            <p style="margin: 0; font-size: 15px; color: #ffffff;">
                                <span t-esc="partner.name"/>
                            </p>

                            <div style="
                                display: inline-block;
                                margin-top: 12px;
                                padding: 6px 14px;
                                border-radius: 999px;
                                background-color: #9b6b90;
                                border: 1px solid #ffffff;
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: bold;
                            ">
                                <t t-if="partner.is_agent">Active Agent</t>
                                <t t-elif="partner.is_membership">Active Member</t>
                                <t t-else="">Contact</t>
                            </div>
                        </div>

                        <!-- Body -->
                        <div style="padding: 24px; background: #ffffff;">

                            <!-- Unique Code -->
                            <div style="
                                margin-bottom: 18px;
                                padding: 14px;
                                border-radius: 16px;
                                background-color: #fff7ed;
                                border: 1px solid #fed7aa;
                                text-align: center;
                            ">
                                <div style="
                                    font-size: 12px;
                                    color: #9a3412;
                                    font-weight: bold;
                                    margin-bottom: 6px;
                                    text-transform: uppercase;
                                    letter-spacing: 0.5px;
                                ">
                                    <t t-if="partner.is_agent">Agent Code</t>
                                    <t t-elif="partner.is_membership">Member Code</t>
                                    <t t-else="">Unique Code</t>
                                </div>

                                <div style="
                                    font-size: 22px;
                                    color: #c05621;
                                    font-weight: bold;
                                ">
                                    <span t-esc="partner.membership_agent_code or '-'"/>
                                </div>
                            </div>

                            <!-- Info -->
                            <table style="
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 13px;
                                margin-bottom: 18px;
                            ">
                                <tr>
                                    <td style="
                                        padding: 10px 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        Email
                                    </td>
                                    <td style="
                                        padding: 10px 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        <span t-esc="partner.email or '-'"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="
                                        padding: 10px 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        Phone
                                    </td>
                                    <td style="
                                        padding: 10px 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        <span t-esc="partner.phone or '-'"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="
                                        padding: 10px 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        Mobile
                                    </td>
                                    <td style="
                                        padding: 10px 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 1px solid #eef2f7;
                                    ">
                                        <span t-esc="partner.mobile or '-'"/>
                                    </td>
                                </tr>
                            </table>

                            <!-- Summary -->
                            <table style="width: 100%; border-collapse: separate; border-spacing: 0;">
                                <tr>
                                    <td style="
                                        width: 49%;
                                        background-color: #f3e8ff;
                                        padding: 16px 10px;
                                        border-radius: 14px;
                                        text-align: center;
                                    ">
                                        <div style="
                                            font-size: 12px;
                                            color: #64748b;
                                            font-weight: bold;
                                            margin-bottom: 6px;
                                        ">
                                            Loyalty Points
                                        </div>
                                        <div style="
                                            font-size: 26px;
                                            color: #875A7B;
                                            font-weight: bold;
                                        ">
                                            <span t-esc="partner.loyalty_points"/>
                                        </div>
                                    </td>

                                    <td style="width: 2%;"></td>

                                    <td style="
                                        width: 49%;
                                        background-color: #e8f4ff;
                                        padding: 16px 10px;
                                        border-radius: 14px;
                                        text-align: center;
                                    ">
                                        <div style="
                                            font-size: 12px;
                                            color: #64748b;
                                            font-weight: bold;
                                            margin-bottom: 6px;
                                        ">
                                            Loyalty Amount
                                        </div>
                                        <div style="
                                            font-size: 26px;
                                            color: #875A7B;
                                            font-weight: bold;
                                        ">
                                            <span t-esc="partner.loyalty_amount"/> TK
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <!-- QR Code -->
                            <t t-if="partner.qr_code">
                                <div style="
                                    margin-top: 22px;
                                    padding: 18px;
                                    border-radius: 18px;
                                    background-color: #fbfcff;
                                    border: 1px solid #edf0f5;
                                    text-align: center;
                                ">
                                    <h3 style="
                                        margin: 0 0 14px;
                                        font-size: 17px;
                                        color: #111827;
                                    ">
                                        QR Code
                                    </h3>

                                    <img t-att-src="'data:image/png;base64,%s' % partner.qr_code.decode('utf-8')"
                                         style="
                                            width: 145px;
                                            height: 145px;
                                            object-fit: contain;
                                            border: 1px solid #e5e7eb;
                                            border-radius: 12px;
                                            padding: 8px;
                                            background: #ffffff;
                                         "/>
                                </div>
                            </t>

                        </div>
                    </div>

                </div>

            </t>
        </t>
    </template>

</odoo>