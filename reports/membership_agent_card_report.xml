<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Exact Portrait ID Card Size: no right/bottom white space -->
    <record id="paperformat_membership_agent_card" model="report.paperformat">
        <field name="name">Exact Portrait ID Card Paper</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">76</field>
        <field name="page_height">145</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>

    <record id="action_report_membership_agent_card" model="ir.actions.report">
        <field name="name">Membership / Agent Card</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dsl_membership_loyalty.report_membership_agent_card_template</field>
        <field name="report_file">dsl_membership_loyalty.report_membership_agent_card_template</field>
        <field name="print_report_name">'%s Card' % (object.name)</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="dsl_membership_loyalty.paperformat_membership_agent_card"/>
    </record>

    <template id="report_membership_agent_card_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="partner">

                <style>
                    @page {
                        size: 76mm 145mm;
                        margin: 0;
                        padding: 0;
                    }

                    html,
                    body {
                        margin: 0 !important;
                        padding: 0 !important;
                        width: 76mm !important;
                        height: 145mm !important;
                        min-width: 76mm !important;
                        max-width: 76mm !important;
                        min-height: 145mm !important;
                        max-height: 145mm !important;
                        overflow: hidden !important;
                        background: #ffffff !important;
                    }

                    .page {
                        margin: 0 !important;
                        padding: 0 !important;
                        width: 76mm !important;
                        height: 145mm !important;
                        min-width: 76mm !important;
                        max-width: 76mm !important;
                        min-height: 145mm !important;
                        max-height: 145mm !important;
                        overflow: hidden !important;
                        background: #ffffff !important;
                        page-break-after: avoid !important;
                    }

                    * {
                        box-sizing: border-box;
                    }
                </style>

                <div class="page" style="
                    font-family: Arial, sans-serif;
                    margin: 0 !important;
                    padding: 0 !important;
                    width: 76mm !important;
                    height: 145mm !important;
                    overflow: hidden !important;
                    background: #ffffff;
                ">

                    <div style="
                        width: 76mm !important;
                        height: 145mm !important;
                        margin: 0 !important;
                        padding: 0 !important;
                        overflow: hidden !important;
                        background: #ffffff;
                        border: none;
                        box-shadow: none;
                    ">

                        <!-- Header -->
                        <div style="
                            width: 76mm !important;
                            background-color: #875A7B;
                            color: #ffffff;
                            padding: 5mm 5mm 4.5mm;
                            text-align: center;
                        ">

                            <t t-if="partner.image_1920">
                                <img t-att-src="'data:image/png;base64,%s' % partner.image_1920.decode('utf-8')"
                                     style="
                                        width: 16mm;
                                        height: 16mm;
                                        border-radius: 50%;
                                        object-fit: cover;
                                        border: 1.2mm solid #ffffff;
                                     "/>
                            </t>

                            <t t-else="">
                                <div style="
                                    width: 16mm;
                                    height: 16mm;
                                    border-radius: 50%;
                                    margin: 0 auto;
                                    border: 1.2mm solid #ffffff;
                                    background-color: #9b6b90;
                                    color: #ffffff;
                                    font-size: 21px;
                                    font-weight: bold;
                                    line-height: 16mm;
                                    text-align: center;
                                ">
                                    <span t-esc="(partner.name or 'U')[:1]"/>
                                </div>
                            </t>

                            <h2 style="
                                margin: 2.4mm 0 0.7mm;
                                font-size: 17px;
                                color: #ffffff;
                                line-height: 1.1;
                            ">
                                <t t-if="partner.is_agent">Agent Card</t>
                                <t t-elif="partner.is_membership">Membership Card</t>
                                <t t-else="">Contact Card</t>
                            </h2>

                            <p style="
                                margin: 0;
                                font-size: 10.5px;
                                color: #ffffff;
                            ">
                                <span t-esc="partner.name"/>
                            </p>

                            <div style="
                                display: inline-block;
                                margin-top: 1.8mm;
                                padding: 0.9mm 3mm;
                                border-radius: 10mm;
                                background-color: #9b6b90;
                                border: 0.3mm solid #ffffff;
                                color: #ffffff;
                                font-size: 7.5px;
                                font-weight: bold;
                            ">
                                <t t-if="partner.is_agent">Active Agent</t>
                                <t t-elif="partner.is_membership">Active Member</t>
                                <t t-else="">Contact</t>
                            </div>
                        </div>

                        <!-- Body -->
                        <div style="
                            width: 76mm !important;
                            padding: 3.6mm 4.5mm;
                            background: #ffffff;
                        ">

                            <!-- Unique Code -->
                            <div style="
                                margin-bottom: 2.7mm;
                                padding: 2.4mm;
                                border-radius: 4mm;
                                background-color: #fff7ed;
                                border: 0.3mm solid #fed7aa;
                                text-align: center;
                            ">
                                <div style="
                                    font-size: 7.5px;
                                    color: #9a3412;
                                    font-weight: bold;
                                    margin-bottom: 0.5mm;
                                    text-transform: uppercase;
                                    letter-spacing: 0.4px;
                                ">
                                    <t t-if="partner.is_agent">Agent Code</t>
                                    <t t-elif="partner.is_membership">Member Code</t>
                                    <t t-else="">Unique Code</t>
                                </div>

                                <div style="
                                    font-size: 16px;
                                    color: #c05621;
                                    font-weight: bold;
                                ">
                                    <span t-esc="partner.membership_agent_code or '-'"/>
                                </div>
                            </div>

                            <!-- Info -->
                            <table style="
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 8.2px;
                                margin-bottom: 2.7mm;
                            ">
                                <tr>
                                    <td style="
                                        padding: 1.25mm 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        Email
                                    </td>
                                    <td style="
                                        padding: 1.25mm 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        <span t-esc="partner.email or '-'"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="
                                        padding: 1.25mm 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        Phone
                                    </td>
                                    <td style="
                                        padding: 1.25mm 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        <span t-esc="partner.phone or '-'"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="
                                        padding: 1.25mm 0;
                                        color: #64748b;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        Mobile
                                    </td>
                                    <td style="
                                        padding: 1.25mm 0;
                                        text-align: right;
                                        color: #111827;
                                        font-weight: bold;
                                        border-bottom: 0.2mm solid #eef2f7;
                                    ">
                                        <span t-esc="partner.mobile or '-'"/>
                                    </td>
                                </tr>
                            </table>

                            <!-- Summary -->
                            <table style="width: 100%; border-collapse: separate; border-spacing: 0;">
                                <tr>
                                    <td style="
                                        width: 49%;
                                        background-color: #f3e8ff;
                                        padding: 2.3mm 2mm;
                                        border-radius: 3.5mm;
                                        text-align: center;
                                    ">
                                        <div style="
                                            font-size: 7.5px;
                                            color: #64748b;
                                            font-weight: bold;
                                            margin-bottom: 0.5mm;
                                        ">
                                            Loyalty Points
                                        </div>
                                        <div style="
                                            font-size: 16px;
                                            color: #875A7B;
                                            font-weight: bold;
                                        ">
                                            <span t-esc="partner.loyalty_points"/>
                                        </div>
                                    </td>

                                    <td style="width: 2%;"></td>

                                    <td style="
                                        width: 49%;
                                        background-color: #e8f4ff;
                                        padding: 2.3mm 2mm;
                                        border-radius: 3.5mm;
                                        text-align: center;
                                    ">
                                        <div style="
                                            font-size: 7.5px;
                                            color: #64748b;
                                            font-weight: bold;
                                            margin-bottom: 0.5mm;
                                        ">
                                            Loyalty Amount
                                        </div>
                                        <div style="
                                            font-size: 15.5px;
                                            color: #875A7B;
                                            font-weight: bold;
                                        ">
                                            <span t-esc="partner.loyalty_amount"/> TK
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <!-- QR Code -->
                            <t t-if="partner.qr_code">
                                <div style="
                                    margin-top: 3mm;
                                    padding: 2.3mm;
                                    border-radius: 4mm;
                                    background-color: #fbfcff;
                                    border: 0.3mm solid #edf0f5;
                                    text-align: center;
                                ">
                                    <h3 style="
                                        margin: 0 0 1.5mm;
                                        font-size: 12px;
                                        color: #111827;
                                    ">
                                        QR Code
                                    </h3>

                                    <img t-att-src="'data:image/png;base64,%s' % partner.qr_code.decode('utf-8')"
                                         style="
                                            width: 29mm;
                                            height: 29mm;
                                            object-fit: contain;
                                            border: 0.3mm solid #e5e7eb;
                                            border-radius: 3mm;
                                            padding: 1mm;
                                            background: #ffffff;
                                         "/>
                                </div>
                            </t>

                        </div>
                    </div>

                </div>

            </t>
        </t>
    </template>

</odoo>