<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_membership_card_template" name="Membership Card">
        <html>
            <head>
                <title>Membership Card</title>
                <style>
                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6f9;
                        margin: 0;
                        padding: 40px;
                    }
                    .membership-card {
                        max-width: 450px;
                        margin: auto;
                        background: #ffffff;
                        border-radius: 12px;
                        padding: 30px;
                        text-align: center;
                        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
                        cursor: pointer;
                    }
                    .membership-card a {
                        text-decoration: none;
                        color: inherit;
                        display: block;
                    }
                    .member-image {
                        width: 120px;
                        height: 120px;
                        border-radius: 50%;
                        object-fit: cover;
                        margin-bottom: 15px;
                        border: 4px solid #875A7B;
                    }
                    .points {
                        font-size: 32px;
                        font-weight: bold;
                        color: #875A7B;
                    }
                    .logout-btn {
                        position: absolute;
                        top: 20px;
                        right: 30px;
                        background: #875A7B;
                        color: white;
                        padding: 10px 18px;
                        border-radius: 6px;
                        text-decoration: none;
                    }
                </style>
            </head>

            <body>
                <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                    Logout
                </a>

                <div class="membership-card">
                    <a href="/my/membership-card">

                        <t t-if="partner.image_1920">
                            <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                class="member-image" />
                        </t>

                        <h2>Membership Card</h2>
                        <hr />

                        <h3>
                            <t t-esc="partner.name" />
                        </h3>

                        <p>
                            <strong>Email:</strong>
                            <t t-esc="partner.email or ''" />
                        </p>

                        <p>
                            <strong>Status:</strong>
                            <t t-if="partner.is_membership">Active Member</t>
                            <t t-else="">Not a Member</t>
                        </p>

                        <p>
                            <strong>Loyalty Points</strong>
                        </p>

                        <div class="points">
                            <t t-esc="partner.loyalty_points" />
                        </div>

                        <p>
                            <strong>Loyalty Amount</strong>
                        </p>

                        <div class="points">
                            <t t-esc="partner.loyalty_amount" /> TK </div>

                    </a>
                </div>
            </body>
        </html>
    </template>

    <template id="portal_membership_card_details_template" name="Membership Card Details">
        <html>
            <head>
                <title>Membership Details</title>
                <style>
                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6f9;
                        margin: 0;
                        padding: 40px;
                    }
                    .details-wrapper {
                        max-width: 900px;
                        margin: auto;
                        display: flex;
                        gap: 25px;
                    }
                    .info-card,
                    .points-card {
                        background: #ffffff;
                        border-radius: 12px;
                        padding: 30px;
                        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
                    }
                    .info-card {
                        width: 60%;
                    }
                    .points-card {
                        width: 40%;
                        text-align: center;
                    }
                    .member-image {
                        width: 120px;
                        height: 120px;
                        border-radius: 50%;
                        object-fit: cover;
                        margin-bottom: 15px;
                        border: 4px solid #875A7B;
                    }
                    .points {
                        font-size: 48px;
                        font-weight: bold;
                        color: #875A7B;
                    }
                    .back-btn {
                        display: inline-block;
                        margin-bottom: 20px;
                        text-decoration: none;
                        color: #875A7B;
                        font-weight: bold;
                    }
                    .logout-btn {
                        position: absolute;
                        top: 20px;
                        right: 30px;
                        background: #875A7B;
                        color: white;
                        padding: 10px 18px;
                        border-radius: 6px;
                        text-decoration: none;
                    }
                </style>
            </head>

            <body>
                <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                    Logout
                </a>

                <a href="/my" class="back-btn">← Back</a>

                <div class="details-wrapper">
                    <div class="info-card">
                        <h2>Member Information</h2>
                        <hr />

                        <t t-if="partner.image_1920">
                            <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                class="member-image" />
                        </t>

                        <p>
                            <strong>Name:</strong>
                            <t t-esc="partner.name" />
                        </p>

                        <p>
                            <strong>Email:</strong>
                            <t t-esc="partner.email or ''" />
                        </p>

                        <p>
                            <strong>Phone:</strong>
                            <t t-esc="partner.phone or ''" />
                        </p>

                        <p>
                            <strong>Mobile:</strong>
                            <t t-esc="partner.mobile or ''" />
                        </p>

                        <p>
                            <strong>Status:</strong>
                            <t t-if="partner.is_membership">Active Member</t>
                            <t t-else="">Not a Member</t>
                        </p>
                    </div>

                    <div class="points-card">
                        <h2>Loyalty Summary</h2>
                        <hr />

                        <p>
                            <strong>Loyalty Points</strong>
                        </p>

                        <div class="points">
                            <t t-esc="partner.loyalty_points" />
                        </div>

                        <p>
                            <strong>Loyalty Amount</strong>
                        </p>

                        <div class="points">
                            <t t-esc="partner.loyalty_amount" /> TK </div>
                    </div>
                </div>
            </body>
        </html>
    </template>

</odoo>