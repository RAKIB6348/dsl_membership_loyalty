<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_membership_card_template" name="Membership Card">
        <html>
            <head>
                <title>Membership Card</title>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

                <style>
                    * {
                        box-sizing: border-box;
                    }

                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6fb;
                        margin: 0;
                        color: #1f2937;
                    }

                    .page-wrapper {
                        min-height: 100vh;
                        padding: 32px 20px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }

                    .logout-btn {
                        position: fixed;
                        top: 22px;
                        right: 28px;
                        background: #875A7B;
                        color: #ffffff;
                        padding: 11px 18px;
                        border-radius: 999px;
                        text-decoration: none;
                        font-weight: 700;
                        box-shadow: 0 8px 18px rgba(135, 90, 123, 0.22);
                    }

                    .membership-card {
                        width: 100%;
                        max-width: 480px;
                        background: #ffffff;
                        border-radius: 24px;
                        overflow: hidden;
                        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.12);
                        border: 1px solid #edf0f5;
                    }

                    .membership-card a {
                        text-decoration: none;
                        color: inherit;
                        display: block;
                    }

                    .card-header {
                        background: linear-gradient(135deg, #875A7B, #5f3f63);
                        color: #ffffff;
                        padding: 34px 28px;
                        text-align: center;
                    }

                    .member-image {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        object-fit: cover;
                        border: 5px solid rgba(255, 255, 255, 0.75);
                        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.18);
                    }

                    .avatar-placeholder {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        margin: auto;
                        background: rgba(255, 255, 255, 0.18);
                        border: 5px solid rgba(255, 255, 255, 0.75);
                        color: #ffffff;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 44px;
                        font-weight: 800;
                    }

                    .card-header h2 {
                        margin: 18px 0 6px;
                        font-size: 28px;
                    }

                    .member-name {
                        margin: 0;
                        font-size: 19px;
                        opacity: 0.95;
                    }

                    .status-badge {
                        display: inline-block;
                        margin-top: 14px;
                        padding: 7px 14px;
                        background: rgba(255, 255, 255, 0.18);
                        border: 1px solid rgba(255, 255, 255, 0.28);
                        border-radius: 999px;
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 700;
                    }

                    .card-body {
                        padding: 26px;
                    }

                    .info-row {
                        display: flex;
                        justify-content: space-between;
                        gap: 18px;
                        padding: 13px 0;
                        border-bottom: 1px solid #f0f2f6;
                    }

                    .info-row strong {
                        color: #6b7280;
                        font-size: 14px;
                    }

                    .info-row span {
                        color: #111827;
                        font-weight: 600;
                        text-align: right;
                        word-break: break-word;
                    }

                    .summary-grid {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 14px;
                        margin-top: 22px;
                    }

                    .summary-box {
                        padding: 18px;
                        border-radius: 18px;
                        text-align: center;
                    }

                    .summary-box.points-box {
                        background: #f3e8ff;
                    }

                    .summary-box.amount-box {
                        background: #e8f4ff;
                    }

                    .summary-label {
                        font-size: 13px;
                        color: #6b7280;
                        font-weight: 700;
                        margin-bottom: 8px;
                    }

                    .summary-value {
                        font-size: 28px;
                        font-weight: 800;
                        color: #875A7B;
                    }

                    .qr-section {
                        margin-top: 22px;
                        padding: 20px;
                        border-radius: 18px;
                        background: #fbfcff;
                        border: 1px solid #edf0f5;
                        text-align: center;
                    }

                    .qr-section h3 {
                        margin: 0 0 14px;
                        font-size: 18px;
                    }

                    .qr-image {
                        width: 150px;
                        height: 150px;
                        object-fit: contain;
                        padding: 8px;
                        border-radius: 14px;
                        background: #ffffff;
                        border: 1px solid #e5e7eb;
                    }

                    .view-details {
                        margin-top: 22px;
                        text-align: center;
                        background: #875A7B;
                        color: #ffffff;
                        padding: 13px 18px;
                        border-radius: 14px;
                        font-weight: 700;
                    }

                    @media (max-width: 520px) {
                        .summary-grid {
                            grid-template-columns: 1fr;
                        }

                        .logout-btn {
                            position: static;
                            display: inline-block;
                            margin: 16px;
                        }

                        .page-wrapper {
                            padding-top: 10px;
                        }
                    }
                </style>
            </head>

            <body>
                <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                    Logout
                </a>

                <div class="page-wrapper">
                    <div class="membership-card">
                        <a href="/my/membership-card">

                            <div class="card-header">
                                <t t-if="partner.image_1920">
                                    <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                         class="member-image"/>
                                </t>
                                <t t-else="">
                                    <div class="avatar-placeholder">
                                        <t t-esc="(partner.name or 'M')[:1]"/>
                                    </div>
                                </t>

                                <h2>Membership Card</h2>

                                <p class="member-name">
                                    <t t-esc="partner.name"/>
                                </p>

                                <span class="status-badge">
                                    <t t-if="partner.is_membership">Active Member</t>
                                    <t t-else="">Not a Member</t>
                                </span>
                            </div>

                            <div class="card-body">
                                <div class="info-row">
                                    <strong>Email</strong>
                                    <span>
                                        <t t-esc="partner.email or '-'"/>
                                    </span>
                                </div>

                                <div class="info-row">
                                    <strong>Phone</strong>
                                    <span>
                                        <t t-esc="partner.phone or '-'"/>
                                    </span>
                                </div>

                                <div class="summary-grid">
                                    <div class="summary-box points-box">
                                        <div class="summary-label">Loyalty Points</div>
                                        <div class="summary-value">
                                            <t t-esc="partner.loyalty_points"/>
                                        </div>
                                    </div>

                                    <div class="summary-box amount-box">
                                        <div class="summary-label">Loyalty Amount</div>
                                        <div class="summary-value">
                                            <t t-esc="partner.loyalty_amount"/> TK
                                        </div>
                                    </div>
                                </div>

                                <t t-if="partner.qr_code">
                                    <div class="qr-section">
                                        <h3>Member QR Code</h3>
                                        <img t-att-src="'/web/image/res.partner/%s/qr_code' % partner.id"
                                             class="qr-image"/>
                                    </div>
                                </t>

                                <div class="view-details">
                                    View Full Details
                                </div>
                            </div>

                        </a>
                    </div>
                </div>
            </body>
        </html>
    </template>


    <template id="portal_membership_card_details_template" name="Membership Card Details">
        <html>
            <head>
                <title>Membership Details</title>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

                <style>
                    * {
                        box-sizing: border-box;
                    }

                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6fb;
                        margin: 0;
                        color: #1f2937;
                    }

                    .details-page {
                        min-height: 100vh;
                        padding: 32px;
                    }

                    .top-actions {
                        max-width: 1050px;
                        margin: 0 auto 20px;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                    }

                    .back-btn,
                    .logout-btn {
                        display: inline-block;
                        text-decoration: none;
                        font-weight: 700;
                        border-radius: 999px;
                        padding: 11px 18px;
                    }

                    .back-btn {
                        color: #875A7B;
                        background: #ffffff;
                        border: 1px solid #eee;
                    }

                    .logout-btn {
                        background: #875A7B;
                        color: #ffffff;
                    }

                    .details-wrapper {
                        max-width: 1050px;
                        margin: auto;
                        display: grid;
                        grid-template-columns: 1.4fr 0.9fr;
                        gap: 24px;
                    }

                    .card {
                        background: #ffffff;
                        border-radius: 24px;
                        padding: 28px;
                        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.10);
                        border: 1px solid #edf0f5;
                    }

                    .profile-header {
                        display: flex;
                        align-items: center;
                        gap: 20px;
                        margin-bottom: 24px;
                    }

                    .member-image {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        object-fit: cover;
                        border: 5px solid #f3e8ff;
                        box-shadow: 0 10px 22px rgba(135, 90, 123, 0.18);
                    }

                    .avatar-placeholder {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        background: #f3e8ff;
                        color: #875A7B;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 44px;
                        font-weight: 800;
                    }

                    .profile-header h2 {
                        margin: 0 0 8px;
                        font-size: 30px;
                    }

                    .status-badge {
                        display: inline-block;
                        padding: 7px 14px;
                        background: #e7f8ee;
                        color: #16803c;
                        border-radius: 999px;
                        font-size: 13px;
                        font-weight: 700;
                    }

                    .section-title {
                        margin: 0 0 18px;
                        font-size: 22px;
                        color: #111827;
                    }

                    .info-grid {
                        display: grid;
                        grid-template-columns: repeat(2, 1fr);
                        gap: 14px;
                    }

                    .info-item {
                        background: #fbfcff;
                        border: 1px solid #edf0f5;
                        border-radius: 16px;
                        padding: 16px;
                    }

                    .info-label {
                        display: block;
                        color: #6b7280;
                        font-size: 13px;
                        font-weight: 700;
                        margin-bottom: 8px;
                    }

                    .info-value {
                        color: #111827;
                        font-size: 16px;
                        font-weight: 600;
                        word-break: break-word;
                    }

                    .summary-card {
                        text-align: center;
                    }

                    .summary-box {
                        padding: 22px;
                        border-radius: 20px;
                        margin-bottom: 16px;
                    }

                    .points-box {
                        background: #f3e8ff;
                    }

                    .amount-box {
                        background: #e8f4ff;
                    }

                    .summary-label {
                        font-size: 14px;
                        color: #6b7280;
                        font-weight: 700;
                        margin-bottom: 10px;
                    }

                    .summary-value {
                        font-size: 42px;
                        font-weight: 800;
                        color: #875A7B;
                    }

                    .qr-box {
                        margin-top: 18px;
                        padding: 22px;
                        background: #fbfcff;
                        border: 1px solid #edf0f5;
                        border-radius: 20px;
                        text-align: center;
                    }

                    .qr-box h3 {
                        margin: 0 0 16px;
                    }

                    .qr-image {
                        width: 180px;
                        height: 180px;
                        object-fit: contain;
                        padding: 10px;
                        background: #ffffff;
                        border: 1px solid #e5e7eb;
                        border-radius: 16px;
                    }

                    @media (max-width: 850px) {
                        .details-page {
                            padding: 18px;
                        }

                        .details-wrapper {
                            grid-template-columns: 1fr;
                        }

                        .profile-header {
                            flex-direction: column;
                            text-align: center;
                        }

                        .info-grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>
            </head>

            <body>
                <div class="details-page">

                    <div class="top-actions">
                        <a href="/my" class="back-btn">← Back</a>

                        <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                            Logout
                        </a>
                    </div>

                    <div class="details-wrapper">

                        <div class="card">
                            <div class="profile-header">
                                <t t-if="partner.image_1920">
                                    <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                         class="member-image"/>
                                </t>
                                <t t-else="">
                                    <div class="avatar-placeholder">
                                        <t t-esc="(partner.name or 'M')[:1]"/>
                                    </div>
                                </t>

                                <div>
                                    <h2>
                                        <t t-esc="partner.name"/>
                                    </h2>

                                    <span class="status-badge">
                                        <t t-if="partner.is_membership">Active Member</t>
                                        <t t-else="">Not a Member</t>
                                    </span>
                                </div>
                            </div>

                            <h3 class="section-title">Member Information</h3>

                            <div class="info-grid">
                                <div class="info-item">
                                    <span class="info-label">Name</span>
                                    <span class="info-value">
                                        <t t-esc="partner.name or '-'"/>
                                    </span>
                                </div>

                                <div class="info-item">
                                    <span class="info-label">Email</span>
                                    <span class="info-value">
                                        <t t-esc="partner.email or '-'"/>
                                    </span>
                                </div>

                                <div class="info-item">
                                    <span class="info-label">Phone</span>
                                    <span class="info-value">
                                        <t t-esc="partner.phone or '-'"/>
                                    </span>
                                </div>

                                <div class="info-item">
                                    <span class="info-label">Mobile</span>
                                    <span class="info-value">
                                        <t t-esc="partner.mobile or '-'"/>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="card summary-card">
                            <h3 class="section-title">Loyalty Summary</h3>

                            <div class="summary-box points-box">
                                <div class="summary-label">Loyalty Points</div>
                                <div class="summary-value">
                                    <t t-esc="partner.loyalty_points"/>
                                </div>
                            </div>

                            <div class="summary-box amount-box">
                                <div class="summary-label">Loyalty Amount</div>
                                <div class="summary-value">
                                    <t t-esc="partner.loyalty_amount"/> TK
                                </div>
                            </div>

                            <t t-if="partner.qr_code">
                                <div class="qr-box">
                                    <h3>Member QR Code</h3>
                                    <img t-att-src="'/web/image/res.partner/%s/qr_code' % partner.id"
                                         class="qr-image"/>
                                </div>
                            </t>
                        </div>

                    </div>
                </div>
            </body>
        </html>
    </template>

</odoo>