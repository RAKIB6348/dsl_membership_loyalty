<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_membership_dashboard_form" model="ir.ui.view">
        <field name="name">membership.dashboard.form</field>
        <field name="model">membership.dashboard</field>
        <field name="arch" type="xml">
            <form string="Membership Dashboard" create="0" edit="0">
                <sheet>

                    <h1 style="text-align:center;">Membership Dashboard</h1>

                    <!-- First row dashboard cards -->
                    <div class="row mt-4">

                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3"
                                style="background:#e8f4ff; border-left:5px solid #0d6efd;">
                                <h3>Total Members</h3>
                                <h1>
                                    <field name="total_members" />
                                </h1>
                                <div class="text-center mt-2">
                                    <button name="action_view_members"
                                        type="object"
                                        string="View"
                                        class="btn btn-primary"
                                        style="width:120px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3"
                                style="background:#eafaf1; border-left:5px solid #198754;">
                                <h3>Total Agents</h3>
                                <h1>
                                    <field name="total_agents" />
                                </h1>
                                <div class="text-center mt-2">
                                    <button name="action_view_agents"
                                        type="object"
                                        string="View"
                                        class="btn btn-success"
                                        style="width:120px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3"
                                style="background:#fff3cd; border-left:5px solid #ffc107;">
                                <h3>Portal Users</h3>
                                <h1>
                                    <field name="total_portal_users" />
                                </h1>
                                <div class="text-center mt-2">
                                    <button name="action_view_portal_users"
                                        type="object"
                                        string="View"
                                        class="btn btn-warning"
                                        style="width:120px;" />
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Second row dashboard cards -->
                    <div class="row mt-4">

                        <div class="col-md-6">
                            <div class="card text-center shadow-sm p-3"
                                style="background:#f3e8ff; border-left:5px solid #6f42c1;">
                                <h3>Today's Members</h3>
                                <h1>
                                    <field name="today_members" />
                                </h1>
                                <div class="text-center mt-2">
                                    <button name="action_view_today_members"
                                        type="object"
                                        string="View"
                                        class="btn btn-info"
                                        style="width:120px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card text-center shadow-sm p-3"
                                style="background:#ffe8e8; border-left:5px solid #dc3545;">
                                <h3>Today's Agents</h3>
                                <h1>
                                    <field name="today_agents" />
                                </h1>
                                <div class="text-center mt-2">
                                    <button name="action_view_today_agents"
                                        type="object"
                                        string="View"
                                        class="btn btn-danger"
                                        style="width:120px;" />
                                </div>
                            </div>
                        </div>

                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Fixed dashboard record -->
    <record id="membership_dashboard_record" model="membership.dashboard">
        <field name="name">Membership Dashboard</field>
    </record>

    <record id="action_membership_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">membership.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_membership_dashboard_form" />
        <field name="res_id" ref="membership_dashboard_record" />
        <field name="target">current</field>
    </record>

</odoo>