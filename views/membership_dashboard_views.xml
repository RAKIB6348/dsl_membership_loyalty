<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_membership_dashboard_form" model="ir.ui.view">
        <field name="name">membership.dashboard.form</field>
        <field name="model">membership.dashboard</field>
        <field name="arch" type="xml">
            <form string="Membership Dashboard" create="0" edit="0">
                <sheet>
                    <div class="oe_title text-center">
                        <h1>Membership Dashboard</h1>
                    </div>

                    <!-- First row dashboard cards -->
                    <div class="row mt-4">
                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3">
                                <h3>Total Members</h3>
                                <h1>
                                    <field name="total_members" />
                                </h1>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3">
                                <h3>Total Agents</h3>
                                <h1>
                                    <field name="total_agents" />
                                </h1>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card text-center shadow-sm p-3">
                                <h3>Portal Users</h3>
                                <h1>
                                    <field name="total_portal_users" />
                                </h1>
                            </div>
                        </div>
                    </div>

                    <!-- Second row dashboard cards -->
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="card text-center shadow-sm p-3">
                                <h3>Today's Members</h3>
                                <h1>
                                    <field name="today_members" />
                                </h1>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card text-center shadow-sm p-3">
                                <h3>Today's Agents</h3>
                                <h1>
                                    <field name="today_agents" />
                                </h1>
                            </div>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Fixed dashboard record -->
    <record id="membership_dashboard_record" model="membership.dashboard">
        <field name="name">Membership Dashboard</field>
    </record>

    <record id="action_membership_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">membership.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_membership_dashboard_form" />
        <field name="res_id" ref="membership_dashboard_record" />
        <field name="target">current</field>
    </record>

</odoo>