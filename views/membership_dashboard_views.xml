<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_membership_dashboard_form" model="ir.ui.view">
        <field name="name">membership.dashboard.form</field>
        <field name="model">membership.dashboard</field>
        <field name="arch" type="xml">
            <form string="Membership Dashboard" create="0" edit="0">
                <sheet>
                    <style>
                        .membership-dashboard {
                            padding: 24px 20px;
                            background: #f8fafc;
                            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
                        }
                        .dash-header {
                            display: flex; justify-content: space-between; align-items: center;
                            margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;
                        }
                        .dash-title { font-size: 28px; font-weight: 700; color: #1e2937; margin: 0; }
                        .dash-subtitle { color: #64748b; font-size: 15px; margin-top: 4px; }

                        .live-badge {
                            background: #dcfce7; color: #166534; font-weight: 700; font-size: 13px;
                            padding: 6px 16px; border-radius: 9999px; display: flex; align-items: center; gap: 8px;
                        }
                        .live-dot {
                            width: 9px; height: 9px; background: #22c55e; border-radius: 50%;
                            animation: pulse 2s infinite;
                        }

                        .section-title {
                            font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px;
                            color: #64748b; margin: 32px 0 16px 4px;
                        }

                        .kpi-grid {
                            display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px;
                        }
                        .kpi-card {
                            background: white; border-radius: 16px; padding: 24px;
                            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); transition: all 0.2s;
                        }
                        .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1); }

                        .kpi-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
                        .kpi-icon {
                            width: 52px; height: 52px; border-radius: 12px; display: flex;
                            align-items: center; justify-content: center; font-size: 26px;
                        }
                        .kpi-value { font-size: 38px; font-weight: 800; color: #0f172a; margin: 8px 0 6px; }
                        .kpi-label { color: #64748b; font-size: 14.5px; font-weight: 500; }

                        .trend {
                            font-size: 13px; font-weight: 600; padding: 4px 12px; border-radius: 999px;
                        }
                        .trend-up { background: #dcfce7; color: #166534; }
                        .trend-down { background: #fee2e2; color: #b91c1c; }

                        .btn-link {
                            color: #2563eb; font-weight: 600; font-size: 13.5px; margin-top: 12px;
                            text-decoration: none;
                        }
                        .btn-link:hover { color: #1e40af; }

                        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
                    </style>

                    <div class="membership-dashboard">

                        <!-- Header -->
                        <div class="dash-header">
                            <div>
                                <h1 class="dash-title">Membership Dashboard</h1>
                                <p class="dash-subtitle">Real-time overview of membership performance and growth</p>
                            </div>
                            <div class="live-badge">
                                <span class="live-dot"></span>
                                LIVE
                            </div>
                        </div>

                        <!-- Overview -->
                        <div class="section-title">Overview</div>
                        <div class="kpi-grid">
                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#dbeafe; color:#1e40af;">
                                        <i class="fa fa-users fa-2x"></i>
                                    </div>
                                    <span class="trend trend-up">↑ 12%</span>
                                </div>
                                <div class="kpi-value"><field name="total_members"/></div>
                                <div class="kpi-label">Total Members</div>
                                <button name="action_view_members" type="object" class="btn-link">View All Members →</button>
                            </div>

                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#ecfdf5; color:#0f766e;">
                                        <i class="fa fa-handshake-o fa-2x"></i>
                                    </div>
                                    <span class="trend trend-up">↑ 8%</span>
                                </div>
                                <div class="kpi-value"><field name="total_agents"/></div>
                                <div class="kpi-label">Total Agents</div>
                                <button name="action_view_agents" type="object" class="btn-link">View All Agents →</button>
                            </div>

                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#f3e8ff; color:#6b21a8;">
                                        <i class="fa fa-globe fa-2x"></i>
                                    </div>
                                    <span class="trend trend-up">↑ 21%</span>
                                </div>
                                <div class="kpi-value"><field name="total_portal_users"/></div>
                                <div class="kpi-label">Active Portal Users</div>
                                <button name="action_view_portal_users" type="object" class="btn-link">View Portal Activity →</button>
                            </div>

                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#fef3c7; color:#854d0e;">
                                        <i class="fa fa-line-chart fa-2x"></i>
                                    </div>
                                </div>
                                <div class="kpi-value"><field name="growth_rate"/>%</div>
                                <div class="kpi-label">Monthly Growth Rate</div>
                            </div>
                        </div>

                        <!-- Today's Performance -->
                        <div class="section-title">Today's Performance</div>
                        <div class="kpi-grid">
                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#ede9fe; color:#4f46e5;">
                                        <i class="fa fa-user-plus fa-2x"></i>
                                    </div>
                                </div>
                                <div class="kpi-value"><field name="today_members"/></div>
                                <div class="kpi-label">New Members Today</div>
                                <div class="trend trend-up" style="margin-top:8px;">Target Progress: 62%</div>
                                <button name="action_view_today_members" type="object" class="btn-link">View Today's Members →</button>
                            </div>

                            <div class="kpi-card">
                                <div class="kpi-header">
                                    <div class="kpi-icon" style="background:#fee2e2; color:#b91c1c;">
                                        <i class="fa fa-user-plus fa-2x"></i>
                                    </div>
                                </div>
                                <div class="kpi-value"><field name="today_agents"/></div>
                                <div class="kpi-label">New Agents Today</div>
                                <div class="trend trend-down" style="margin-top:8px;">Target Progress: 35%</div>
                                <button name="action_view_today_agents" type="object" class="btn-link">View Today's Agents →</button>
                            </div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="membership_dashboard_record" model="membership.dashboard">
        <field name="name">Membership Dashboard</field>
    </record>

    <record id="action_membership_dashboard" model="ir.actions.act_window">
        <field name="name">Membership Dashboard</field>
        <field name="res_model">membership.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_membership_dashboard_form"/>
        <field name="res_id" ref="membership_dashboard_record"/>
        <field name="target">current</field>
    </record>

</odoo>