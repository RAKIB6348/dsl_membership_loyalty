<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_loyalty_configuration_tree" model="ir.ui.view">
        <field name="name">loyalty.configuration.tree</field>
        <field name="model">loyalty.configuration</field>
        <field name="arch" type="xml">
            <tree>
                <field name="point" />
                <field name="amount" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_loyalty_configuration_form" model="ir.ui.view">
        <field name="name">loyalty.configuration.form</field>
        <field name="model">loyalty.configuration</field>
        <field name="arch" type="xml">
            <form string="Loyalty Configuration">
                <sheet>
                    <group>
                        <field name="point" />
                        <field name="amount" />
                        <field name="active" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loyalty_configuration" model="ir.actions.act_window">
        <field name="name">Loyalty Configuration</field>
        <field name="res_model">loyalty.configuration</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>