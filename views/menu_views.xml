<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Membership action: when clicking New, is_membership will be True by default -->
    <record id="action_membership_contacts" model="ir.actions.act_window">
        <field name="name">Membership</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('is_membership', '=', True)]</field>
        <field name="context">{'default_is_membership': True}</field>
    </record>

    <!-- Agent action: when clicking New, is_agent will be True by default -->
    <record id="action_agent_contacts" model="ir.actions.act_window">
        <field name="name">Agent</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('is_agent', '=', True)]</field>
        <field name="context">{'default_is_agent': True}</field>
    </record>

    <!-- Root menu for Membership and Loyalty Management -->
    <menuitem id="membership_loyalty_root_menu"
        name="Membership &amp; Loyalty"
        sequence="10" />

    <!-- Dashboard submenu -->
    <menuitem id="membership_dashboard_submenu"
        name="Dashboard"
        parent="membership_loyalty_root_menu"
        action="action_membership_dashboard"
        sequence="5" />

    <!-- Membership submenu: opens only membership contacts -->
    <menuitem id="membership_submenu"
        name="Membership"
        parent="membership_loyalty_root_menu"
        action="action_membership_contacts"
        sequence="10" />

    <!-- Agent submenu: opens only agent contacts -->
    <menuitem id="agent_submenu"
        name="Agent"
        parent="membership_loyalty_root_menu"
        action="action_agent_contacts"
        sequence="20" />

    
    <!-- Configuration parent menu -->
    <menuitem id="membership_configuration_menu"
        name="Configuration"
        parent="membership_loyalty_root_menu"
        sequence="30" />

    <!-- Loyalty Point Configuration submenu -->
    <menuitem id="loyalty_configuration_submenu"
        name="Loyalty Point Configuration"
        parent="membership_configuration_menu"
        action="action_loyalty_configuration"
        sequence="10" />

</odoo>