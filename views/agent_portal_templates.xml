<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_agent_dashboard_template" name="Agent Dashboard">
        <html>
            <head>
                <title>Agent Dashboard</title>
                <style>
                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6f9;
                        margin: 0;
                        padding: 40px;
                    }

                    .agent-dashboard-wrapper {
                        max-width: 1100px;
                        margin: auto;
                        display: flex;
                        gap: 25px;
                    }

                    .agent-info,
                    .member-search {
                        background: #ffffff;
                        border-radius: 12px;
                        padding: 30px;
                        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
                    }

                    .agent-info {
                        width: 40%;
                    }

                    .member-search {
                        width: 60%;
                    }

                    .agent-image,
                    .member-image {
                        width: 120px;
                        height: 120px;
                        border-radius: 50%;
                        object-fit: cover;
                        border: 4px solid #875A7B;
                        margin-bottom: 15px;
                    }

                    .points {
                        font-size: 34px;
                        font-weight: bold;
                        color: #875A7B;
                    }

                    .agent-btn {
                        margin-top: 15px;
                        padding: 12px 24px;
                        border: none;
                        border-radius: 8px;
                        background: #875A7B;
                        color: white;
                        font-size: 16px;
                        cursor: pointer;
                    }

                    .error-message {
                        margin-top: 15px;
                        color: #dc3545;
                        font-weight: bold;
                    }

                    .success-message {
                        margin-top: 15px;
                        color: green;
                        font-weight: bold;
                    }

                    .member-result {
                        margin-top: 25px;
                        padding: 20px;
                        border-radius: 10px;
                        background: #f8f9fa;
                        border-left: 5px solid #875A7B;
                    }

                    .form-control {
                        width: 100%;
                        padding: 10px;
                        border: 1px solid #ddd;
                        border-radius: 6px;
                        margin-top: 6px;
                        margin-bottom: 10px;
                    }

                    .logout-btn {
                        position: absolute;
                        top: 20px;
                        right: 30px;
                        background: #875A7B;
                        color: white;
                        padding: 10px 18px;
                        border-radius: 6px;
                        text-decoration: none;
                    }
                </style>
            </head>

            <body>
                <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                    Logout
                </a>

                <h1 style="text-align:center;">Agent Dashboard</h1>

                <div class="agent-dashboard-wrapper">

                    <div class="agent-info">
                        <h2>Agent Information</h2>
                        <hr />

                        <t t-if="partner.image_1920">
                            <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                class="agent-image" />
                        </t>

                        <p>
                            <strong>Name:</strong>
                            <t t-esc="partner.name" />
                        </p>
                        <p>
                            <strong>Email:</strong>
                            <t t-esc="partner.email or ''" />
                        </p>
                        <p>
                            <strong>Phone:</strong>
                            <t t-esc="partner.phone or ''" />
                        </p>
                        <p>
                            <strong>Mobile:</strong>
                            <t t-esc="partner.mobile or ''" />
                        </p>
                        <p><strong>Status:</strong> Active Agent</p>

                        <div style="display:flex; gap:15px; margin-top:20px;">
                            <div
                                style="width:50%; background:#f3e8ff; padding:15px; border-radius:10px; text-align:center;">
                                <h4>Points</h4>
                                <div class="points">
                                    <t t-esc="partner.loyalty_points" />
                                </div>
                            </div>

                            <div
                                style="width:50%; background:#e8f4ff; padding:15px; border-radius:10px; text-align:center;">
                                <h4>TK</h4>
                                <div class="points">
                                    <t t-esc="partner.loyalty_amount" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="member-search">
                        <h2>Member Lookup</h2>
                        <hr />

                        <p>Search member by name, phone or email</p>

                        <form action="/my/agent/member-search" method="post">
                            <input type="hidden"
                                name="csrf_token"
                                t-att-value="request.csrf_token()" />

                            <input type="text"
                                name="member_search"
                                class="form-control"
                                placeholder="Enter member name, phone or email"
                                t-att-value="search_value or ''" />

                            <button type="submit" class="agent-btn">
                                Search Member
                            </button>
                        </form>

                        <t t-if="search_error">
                            <div class="error-message">
                                <t t-esc="search_error" />
                            </div>
                        </t>

                        <t t-if="success_message">
                            <div class="success-message">
                                <t t-esc="success_message" />
                            </div>
                        </t>

                        <t t-if="searched_member">
                            <div class="member-result">
                                <h3>Member Information</h3>
                                <hr />

                                <t t-if="searched_member.image_1920">
                                    <img
                                        t-att-src="'/web/image/res.partner/%s/image_1920' % searched_member.id"
                                        class="member-image" />
                                </t>

                                <p>
                                    <strong>Name:</strong>
                                    <t t-esc="searched_member.name" />
                                </p>
                                <p>
                                    <strong>Email:</strong>
                                    <t t-esc="searched_member.email or ''" />
                                </p>
                                <p>
                                    <strong>Phone:</strong>
                                    <t t-esc="searched_member.phone or ''" />
                                </p>
                                <p>
                                    <strong>Mobile:</strong>
                                    <t t-esc="searched_member.mobile or ''" />
                                </p>
                                <p>
                                    <strong>Loyalty Points:</strong>
                                    <t t-esc="searched_member.loyalty_points" />
                                </p>
                                <p><strong>Loyalty Amount:</strong> <t
                                        t-esc="searched_member.loyalty_amount" /> TK</p>

                                <hr />

                                <h3>Room Booking</h3>

                                <form action="/my/agent/room-booking" method="post">
                                    <input type="hidden"
                                        name="csrf_token"
                                        t-att-value="request.csrf_token()" />

                                    <input type="hidden"
                                        name="member_id"
                                        t-att-value="searched_member.id" />

                                    <label>
                                        <strong>Room No</strong>
                                    </label>
                                    <input type="text"
                                        name="room_no"
                                        class="form-control"
                                        placeholder="Enter room number" />

                                    <label>
                                        <strong>Room Charge</strong>
                                    </label>
                                    <input type="number"
                                        name="room_charge"
                                        class="form-control"
                                        placeholder="Enter room charge" />

                                    <label>
                                        <strong>Use Loyalty Points</strong>
                                    </label>
                                    <input type="number"
                                        name="used_points"
                                        class="form-control"
                                        placeholder="Enter points to use" />

                                    <button type="submit" class="agent-btn">
                                        Book Room
                                    </button>
                                </form>
                            </div>
                        </t>
                    </div>

                </div>
            </body>
        </html>
    </template>

</odoo>