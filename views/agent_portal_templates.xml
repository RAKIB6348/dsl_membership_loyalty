<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_agent_dashboard_template" name="Agent Dashboard">
        <html>
            <head>
                <title>Agent Dashboard</title>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

                <style>
                    * {
                        box-sizing: border-box;
                    }

                    body {
                        font-family: Arial, sans-serif;
                        background: #f4f6fb;
                        margin: 0;
                        color: #1f2937;
                    }

                    .agent-page {
                        min-height: 100vh;
                        padding: 32px;
                    }

                    .top-header {
                        max-width: 1180px;
                        margin: 0 auto 24px auto;
                        background: linear-gradient(135deg, #875A7B, #5f3f63);
                        color: #ffffff;
                        border-radius: 20px;
                        padding: 28px 32px;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        box-shadow: 0 12px 30px rgba(135, 90, 123, 0.25);
                    }

                    .top-header h1 {
                        margin: 0;
                        font-size: 30px;
                        font-weight: 700;
                    }

                    .top-header p {
                        margin: 8px 0 0;
                        opacity: 0.9;
                    }

                    .logout-btn {
                        background: rgba(255, 255, 255, 0.16);
                        color: #ffffff;
                        padding: 11px 18px;
                        border-radius: 999px;
                        text-decoration: none;
                        border: 1px solid rgba(255, 255, 255, 0.28);
                        font-weight: 600;
                    }

                    .logout-btn:hover {
                        background: #ffffff;
                        color: #875A7B;
                    }

                    .agent-dashboard-wrapper {
                        max-width: 1180px;
                        margin: auto;
                        display: grid;
                        grid-template-columns: 380px 1fr;
                        gap: 24px;
                    }

                    .card {
                        background: #ffffff;
                        border-radius: 20px;
                        padding: 26px;
                        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
                        border: 1px solid #eef0f5;
                    }

                    .card-title {
                        margin: 0 0 18px;
                        font-size: 22px;
                        font-weight: 700;
                        color: #111827;
                    }

                    .agent-profile {
                        text-align: center;
                    }

                    .agent-image,
                    .member-image {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        object-fit: cover;
                        border: 5px solid #f3e8ff;
                        box-shadow: 0 8px 18px rgba(135, 90, 123, 0.18);
                    }

                    .avatar-placeholder {
                        width: 118px;
                        height: 118px;
                        border-radius: 50%;
                        margin: 0 auto;
                        background: #f3e8ff;
                        color: #875A7B;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 42px;
                        font-weight: 700;
                        border: 5px solid #ffffff;
                        box-shadow: 0 8px 18px rgba(135, 90, 123, 0.18);
                    }

                    .agent-name {
                        margin: 16px 0 4px;
                        font-size: 26px;
                        font-weight: 700;
                    }

                    .status-badge {
                        display: inline-block;
                        margin-top: 8px;
                        padding: 6px 12px;
                        background: #e7f8ee;
                        color: #16803c;
                        border-radius: 999px;
                        font-size: 13px;
                        font-weight: 700;
                    }

                    .info-list {
                        margin-top: 22px;
                        text-align: left;
                    }

                    .info-row {
                        display: flex;
                        justify-content: space-between;
                        gap: 16px;
                        padding: 12px 0;
                        border-bottom: 1px solid #f0f2f6;
                        font-size: 14px;
                    }

                    .info-row strong {
                        color: #6b7280;
                        min-width: 80px;
                    }

                    .info-row span {
                        color: #111827;
                        text-align: right;
                        word-break: break-word;
                    }

                    .stats-grid {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 14px;
                        margin-top: 22px;
                    }

                    .stat-card {
                        border-radius: 16px;
                        padding: 18px;
                        text-align: center;
                    }

                    .stat-card.points-card {
                        background: #f3e8ff;
                    }

                    .stat-card.amount-card {
                        background: #e8f4ff;
                    }

                    .stat-label {
                        font-size: 13px;
                        color: #6b7280;
                        font-weight: 700;
                        margin-bottom: 8px;
                    }

                    .stat-value {
                        font-size: 28px;
                        font-weight: 800;
                        color: #875A7B;
                    }

                    .search-panel-header {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        gap: 18px;
                        margin-bottom: 18px;
                    }

                    .search-panel-header p {
                        margin: 6px 0 0;
                        color: #6b7280;
                    }

                    .search-box {
                        display: flex;
                        gap: 12px;
                        background: #f8fafc;
                        padding: 14px;
                        border-radius: 16px;
                        border: 1px solid #edf0f5;
                    }

                    .form-control {
                        width: 100%;
                        padding: 13px 14px;
                        border: 1px solid #d8dde8;
                        border-radius: 12px;
                        font-size: 15px;
                        outline: none;
                        background: #ffffff;
                    }

                    .form-control:focus {
                        border-color: #875A7B;
                        box-shadow: 0 0 0 3px rgba(135, 90, 123, 0.12);
                    }

                    .agent-btn {
                        padding: 13px 22px;
                        border: none;
                        border-radius: 12px;
                        background: #875A7B;
                        color: #ffffff;
                        font-size: 15px;
                        font-weight: 700;
                        cursor: pointer;
                        white-space: nowrap;
                    }

                    .agent-btn:hover {
                        background: #74496a;
                    }

                    .error-message,
                    .success-message {
                        margin-top: 16px;
                        padding: 13px 15px;
                        border-radius: 12px;
                        font-weight: 700;
                    }

                    .error-message {
                        color: #b42318;
                        background: #fff1f0;
                        border: 1px solid #ffd0cc;
                    }

                    .success-message {
                        color: #16703c;
                        background: #ecfdf3;
                        border: 1px solid #bbf7d0;
                    }

                    .member-result {
                        margin-top: 24px;
                        padding: 22px;
                        border-radius: 18px;
                        background: #fbfcff;
                        border: 1px solid #edf0f5;
                    }

                    .member-header {
                        display: flex;
                        align-items: center;
                        gap: 18px;
                        margin-bottom: 18px;
                    }

                    .member-header h3 {
                        margin: 0;
                        font-size: 22px;
                    }

                    .member-header p {
                        margin: 6px 0 0;
                        color: #6b7280;
                    }

                    .member-details {
                        display: grid;
                        grid-template-columns: repeat(2, 1fr);
                        gap: 12px;
                        margin-bottom: 22px;
                    }

                    .detail-item {
                        background: #ffffff;
                        border: 1px solid #edf0f5;
                        border-radius: 14px;
                        padding: 14px;
                    }

                    .detail-label {
                        display: block;
                        color: #6b7280;
                        font-size: 13px;
                        font-weight: 700;
                        margin-bottom: 6px;
                    }

                    .detail-value {
                        color: #111827;
                        font-size: 15px;
                        font-weight: 600;
                        word-break: break-word;
                    }

                    .booking-box {
                        margin-top: 20px;
                        padding: 22px;
                        background: #ffffff;
                        border-radius: 18px;
                        border: 1px solid #edf0f5;
                    }

                    .booking-box h3 {
                        margin-top: 0;
                        margin-bottom: 16px;
                    }

                    .form-grid {
                        display: grid;
                        grid-template-columns: repeat(3, 1fr);
                        gap: 14px;
                    }

                    .form-group label {
                        display: block;
                        margin-bottom: 7px;
                        font-weight: 700;
                        color: #374151;
                        font-size: 14px;
                    }

                    .booking-action {
                        margin-top: 16px;
                    }

                    @media (max-width: 900px) {
                        .agent-page {
                            padding: 18px;
                        }

                        .top-header {
                            flex-direction: column;
                            align-items: flex-start;
                            gap: 16px;
                        }

                        .agent-dashboard-wrapper {
                            grid-template-columns: 1fr;
                        }

                        .search-box {
                            flex-direction: column;
                        }

                        .member-details,
                        .form-grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>
            </head>

            <body>
                <div class="agent-page">

                    <div class="top-header">
                        <div>
                            <h1>Agent Dashboard</h1>
                            <p>Search members, view loyalty points, and create room bookings.</p>
                        </div>

                        <a href="/web/session/logout?redirect=/web/login" class="logout-btn">
                            Logout
                        </a>
                    </div>

                    <div class="agent-dashboard-wrapper">

                        <div class="card agent-info">
                            <div class="agent-profile">
                                <t t-if="partner.image_1920">
                                    <img t-att-src="'/web/image/res.partner/%s/image_1920' % partner.id"
                                         class="agent-image"/>
                                </t>
                                <t t-else="">
                                    <div class="avatar-placeholder">
                                        <t t-esc="(partner.name or 'A')[:1]"/>
                                    </div>
                                </t>

                                <h2 class="agent-name">
                                    <t t-esc="partner.name"/>
                                </h2>

                                <span class="status-badge">Active Agent</span>
                            </div>

                            <div class="stats-grid">
                                <div class="stat-card points-card">
                                    <div class="stat-label">Loyalty Points</div>
                                    <div class="stat-value">
                                        <t t-esc="partner.loyalty_points"/>
                                    </div>
                                </div>

                                <div class="stat-card amount-card">
                                    <div class="stat-label">Amount</div>
                                    <div class="stat-value">
                                        <t t-esc="partner.loyalty_amount"/> TK
                                    </div>
                                </div>
                            </div>

                            <div class="info-list">
                                <div class="info-row">
                                    <strong>Email</strong>
                                    <span><t t-esc="partner.email or '-'"/></span>
                                </div>
                                <div class="info-row">
                                    <strong>Phone</strong>
                                    <span><t t-esc="partner.phone or '-'"/></span>
                                </div>
                                <div class="info-row">
                                    <strong>Mobile</strong>
                                    <span><t t-esc="partner.mobile or '-'"/></span>
                                </div>
                            </div>
                        </div>

                        <div class="card member-search">
                            <div class="search-panel-header">
                                <div>
                                    <h2 class="card-title">Member Lookup</h2>
                                    <p>Search member by name, phone, or email address.</p>
                                </div>
                            </div>

                            <form action="/my/agent/member-search" method="post">
                                <input type="hidden"
                                       name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <div class="search-box">
                                    <input type="text"
                                           name="member_search"
                                           class="form-control"
                                           placeholder="Enter member name, phone or email"
                                           t-att-value="search_value or ''"/>

                                    <button type="submit" class="agent-btn">
                                        Search Member
                                    </button>
                                </div>
                            </form>

                            <t t-if="search_error">
                                <div class="error-message">
                                    <t t-esc="search_error"/>
                                </div>
                            </t>

                            <t t-if="success_message">
                                <div class="success-message">
                                    <t t-esc="success_message"/>
                                </div>
                            </t>

                            <t t-if="searched_member">
                                <div class="member-result">

                                    <div class="member-header">
                                        <t t-if="searched_member.image_1920">
                                            <img t-att-src="'/web/image/res.partner/%s/image_1920' % searched_member.id"
                                                 class="member-image"/>
                                        </t>
                                        <t t-else="">
                                            <div class="avatar-placeholder">
                                                <t t-esc="(searched_member.name or 'M')[:1]"/>
                                            </div>
                                        </t>

                                        <div>
                                            <h3>
                                                <t t-esc="searched_member.name"/>
                                            </h3>
                                            <p>Membership customer information</p>
                                        </div>
                                    </div>

                                    <div class="member-details">
                                        <div class="detail-item">
                                            <span class="detail-label">Email</span>
                                            <span class="detail-value">
                                                <t t-esc="searched_member.email or '-'"/>
                                            </span>
                                        </div>

                                        <div class="detail-item">
                                            <span class="detail-label">Phone</span>
                                            <span class="detail-value">
                                                <t t-esc="searched_member.phone or '-'"/>
                                            </span>
                                        </div>

                                        <div class="detail-item">
                                            <span class="detail-label">Mobile</span>
                                            <span class="detail-value">
                                                <t t-esc="searched_member.mobile or '-'"/>
                                            </span>
                                        </div>

                                        <div class="detail-item">
                                            <span class="detail-label">Loyalty Points</span>
                                            <span class="detail-value">
                                                <t t-esc="searched_member.loyalty_points"/>
                                            </span>
                                        </div>

                                        <div class="detail-item">
                                            <span class="detail-label">Loyalty Amount</span>
                                            <span class="detail-value">
                                                <t t-esc="searched_member.loyalty_amount"/> TK
                                            </span>
                                        </div>
                                    </div>

                                    <div class="booking-box">
                                        <h3>Room Booking</h3>

                                        <form action="/my/agent/room-booking" method="post">
                                            <input type="hidden"
                                                   name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>

                                            <input type="hidden"
                                                   name="member_id"
                                                   t-att-value="searched_member.id"/>

                                            <div class="form-grid">
                                                <div class="form-group">
                                                    <label>Room No</label>
                                                    <input type="text"
                                                           name="room_no"
                                                           class="form-control"
                                                           placeholder="Room number"/>
                                                </div>

                                                <div class="form-group">
                                                    <label>Room Charge</label>
                                                    <input type="number"
                                                           name="room_charge"
                                                           class="form-control"
                                                           placeholder="Room charge"/>
                                                </div>

                                                <div class="form-group">
                                                    <label>Use Points</label>
                                                    <input type="number"
                                                           name="used_points"
                                                           class="form-control"
                                                           placeholder="Points to use"/>
                                                </div>
                                            </div>

                                            <div class="booking-action">
                                                <button type="submit" class="agent-btn">
                                                    Book Room
                                                </button>
                                            </div>
                                        </form>
                                    </div>

                                </div>
                            </t>
                        </div>

                    </div>
                </div>
            </body>
        </html>
    </template>

</odoo>